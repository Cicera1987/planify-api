{
  "compilerOptions": {
    // Modularidade e interoperabilidade
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,

    // Saida do código
    "target": "ES2020",
    "outDir": "./dist",
    "strict": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // decoração e Metadados
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // Verificação de tipos (TS)
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "allowJs": true,

    // Resolução de caminho e tipos
    "baseUrl": "./",
    "typeRoots": ["./node_modules/@types", "./src/types"],

    // Outras operações e configurações
    "removeComments": true,
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
